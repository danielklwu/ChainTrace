# Copy this file to .env and fill in your credentials.
# ChainTrace loads this automatically at startup via python-dotenv.

# --- Required ---

# Google Gemini API key
# https://ai.google.dev/
GOOGLE_API_KEY=

# Search API key (choose one and set the provider accordingly)
SERPAPI_KEY=
# GOOGLE_CUSTOM_SEARCH_KEY=
# GOOGLE_CUSTOM_SEARCH_CX=

# --- Optional ---

# Gemini model to use (default: gemini-2.0-flash)
# CHAINTRACE_GEMINI_MODEL=gemini-2.0-flash

# Override the default cache directory
# CHAINTRACE_CACHE_DIR=cache
